# Local-demo backend environment example.
# This file is intentionally no-key and deterministic by default.
# Production-demo and CI/test templates live under ../docs/deployment/.

# Application
APP_NAME="Enterprise Multi-Agent OS"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REDACTION_ENABLED=true
METRICS_ENABLED=true
METRICS_ROUTE_ENABLED=true
METRICS_MAX_PATH_LABEL_LENGTH=120

# Infrastructure
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_os
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=enterprise-multi-agent-os

# Authentication: local-demo only. Replace through deployment environment.
JWT_SECRET_KEY=development-only-change-me-32-bytes-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM provider abstraction: fake provider and deterministic runtime by default.
LLM_PROVIDER=fake
LLM_MODEL=
LLM_RUNTIME_ENABLED=false
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_PROVIDER=fake

# Optional real-provider local experiments. Leave empty for no-key demo.
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Embeddings and RAG: fake embeddings and RAG disabled by default.
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-hash-embedding
EMBEDDING_DIMENSIONS=64
EMBEDDING_BATCH_SIZE=32

RAG_ENABLED=false
RAG_TOP_K=3
RAG_MINIMUM_SCORE=0.0
RAG_MAX_CONTEXT_CHARS=3000
RAG_EVENT_PAYLOAD_MAX_CHARS=2000

# Readiness checks: bounded dependency probe timeout.
READINESS_TIMEOUT_SECONDS=2.0
