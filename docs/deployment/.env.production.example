# Production-demo environment template.
# Placeholder values only. Do not commit real .env files or real secrets.

# Backend application
APP_NAME="Enterprise Multi-Agent OS"
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=https://frontend.example.test
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REDACTION_ENABLED=true
METRICS_ENABLED=true
METRICS_ROUTE_ENABLED=true
METRICS_MAX_PATH_LABEL_LENGTH=120

# Backend infrastructure
DATABASE_URL=postgresql+asyncpg://enterprise_os:change-me-in-production@postgres:5432/enterprise_os
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-in-production
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET_NAME=enterprise-multi-agent-os

# Stateful service bootstrap values for docker-compose.prod.yml.
POSTGRES_USER=enterprise_os
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=enterprise_os
BACKEND_PUBLIC_PORT=8000
FRONTEND_PUBLIC_PORT=3000

# Backend auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM provider abstraction: no-key deterministic defaults.
LLM_PROVIDER=fake
LLM_MODEL=
LLM_RUNTIME_ENABLED=false
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_PROVIDER=fake
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OLLAMA_BASE_URL=http://ollama.example.internal:11434
OLLAMA_MODEL=

# Embeddings and RAG: no-key defaults.
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-hash-embedding
EMBEDDING_DIMENSIONS=64
EMBEDDING_BATCH_SIZE=32
RAG_ENABLED=false
RAG_TOP_K=3
RAG_MINIMUM_SCORE=0.0
RAG_MAX_CONTEXT_CHARS=3000
RAG_EVENT_PAYLOAD_MAX_CHARS=2000
READINESS_TIMEOUT_SECONDS=2.0

# Frontend public runtime values.
# These are browser-visible and must never contain secrets.
NEXT_PUBLIC_API_BASE_URL=https://api.example.test/api/v1
NEXT_PUBLIC_WS_BASE_URL=wss://api.example.test/api/v1
